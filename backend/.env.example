# Environment Variables
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=todo_db
DB_USER=postgres
DB_PASSWORD=postgres123

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
